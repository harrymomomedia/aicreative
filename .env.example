# ─────────────────────────────────────────────────────────────────────────────
# aicreative .env — TEMPLATE. Replace every <...> with the real value.
# Real values live in your LOCAL /Users/harry/aicreative/.env — copy them from
# there (or scp the whole .env). NEVER commit a filled-in copy; .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Transcription / Voice (ElevenLabs) — REQUIRED for dissect QA, captions, TTS, cloning
ELEVENLABS_API_KEY=<your_elevenlabs_api_key>

# ── Image + Video generation ────────────────────────────────────────────────
KIE_API_KEY=<your_kie_api_key>                    # gpt-image-2, nano-banana, Kling, KIE Veo/Seedance
POYO_API_KEY=<your_poyo_api_key>                  # Veo 3.1 Fast ($0.10/clip) — default Veo host
OPENROUTER_API_KEY=<your_openrouter_api_key>      # Seedance/Kling/Veo/Sora/Wan pay-per-use
OPENROUTER_ADCLI_KEY=<your_openrouter_adcli_key>  # preferred OpenRouter key for this project
USEAPI_TOKEN=<your_useapi_token>                  # Seedance/Kling/Runway/google-flow (unlimited)
FAL_KEY=<your_fal_key>                            # VEED bg-removal, fal-hosted ElevenLabs STS
REPLICATE_API_TOKEN=<your_replicate_api_token>    # RVM matting, Real-ESRGAN upscale, p-video
EVOLINK_API_KEY=<your_evolink_api_key>            # 3rd Veo host (KIE/Poyo/EvoLink rotation)
OPENAI_API_KEY=<your_openai_api_key>              # OpenAI gpt-image-2 fallback (KIE is default)

# ── Captions (optional — only if you call these APIs) ───────────────────────
OPUSCLIP_API_KEY=<your_opusclip_api_key>
SUBMAGIC_API_KEY=<your_submagic_api_key>

# ── AdMachin (publish / launch) ─────────────────────────────────────────────
ADMACHIN_PAT=<your_admachin_pat>                  # looks like admachin_pat_... (shown once)
ADMACHIN_API_BASE=https://admachin.com            # config, not a secret — leave as-is

# ── google-flow (free Veo 3.1 Lite) config + CapSolver captcha keys ─────────
USEAPI_EXPLORE=true                               # config flag (explore/unlimited mode) — not a secret
GOOGLEFLOW_EMAIL=<your_googleflow_account_email>  # the google-flow account email
ANTICAPTCHA_API_KEY=<your_anticaptcha_api_key>
YESCAPTCHA_API_KEY=<your_yescaptcha_api_key>
SOLVECAPTCHA_API_KEY=<your_solvecaptcha_api_key>

# ── Optional / local-only (safe to omit on a headless cloud box) ────────────
# ADMACHIN_MCP_JS=/path/to/admachin-mcp/dist/index.js  # only if you run the AdMachin MCP server on this box
# POD_MODEL=                                            # podcast_omni_produce.py model selector
# EMOJI_DEBUG=                                          # caption emoji debug flag
